{
  "multipart": [
    {
      "apply": {
        "model": "irregular_implements:block/redstone_plate"
      }
    },
    {
      "apply": {
        "model": "irregular_implements:block/redstone_plate_inactive"
      }
    },
    {
      "apply": {
        "model": "irregular_implements:block/redstone_plate_input"
      },
      "when": {
        "input": "north"
      }
    },
    {
      "apply": {
        "model": "irregular_implements:block/redstone_plate_powered_output"
      },
      "when": {
        "powered_output": "north"
      }
    },
    {
      "apply": {
        "model": "irregular_implements:block/redstone_plate_unpowered_output"
      },
      "when": {
        "unpowered_output": "north"
      }
    },
    {
      "apply": {
        "model": "irregular_implements:block/redstone_plate_inactive",
        "y": 90
      }
    },
    {
      "apply": {
        "model": "irregular_implements:block/redstone_plate_input",
        "y": 90
      },
      "when": {
        "input": "east"
      }
    },
    {
      "apply": {
        "model": "irregular_implements:block/redstone_plate_powered_output",
        "y": 90
      },
      "when": {
        "powered_output": "east"
      }
    },
    {
      "apply": {
        "model": "irregular_implements:block/redstone_plate_unpowered_output",
        "y": 90
      },
      "when": {
        "unpowered_output": "east"
      }
    },
    {
      "apply": {
        "model": "irregular_implements:block/redstone_plate_inactive",
        "y": 180
      }
    },
    {
      "apply": {
        "model": "irregular_implements:block/redstone_plate_input",
        "y": 180
      },
      "when": {
        "input": "south"
      }
    },
    {
      "apply": {
        "model": "irregular_implements:block/redstone_plate_powered_output",
        "y": 180
      },
      "when": {
        "powered_output": "south"
      }
    },
    {
      "apply": {
        "model": "irregular_implements:block/redstone_plate_unpowered_output",
        "y": 180
      },
      "when": {
        "unpowered_output": "south"
      }
    },
    {
      "apply": {
        "model": "irregular_implements:block/redstone_plate_inactive",
        "y": 270
      }
    },
    {
      "apply": {
        "model": "irregular_implements:block/redstone_plate_input",
        "y": 270
      },
      "when": {
        "input": "west"
      }
    },
    {
      "apply": {
        "model": "irregular_implements:block/redstone_plate_powered_output",
        "y": 270
      },
      "when": {
        "powered_output": "west"
      }
    },
    {
      "apply": {
        "model": "irregular_implements:block/redstone_plate_unpowered_output",
        "y": 270
      },
      "when": {
        "unpowered_output": "west"
      }
    }
  ]
}